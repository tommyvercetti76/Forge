# ── Forge .gitignore ─────────────────────────────────────────────────

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*

# Python bytecode / caches
__pycache__/
*.py[cod]
*.pyo
*.pyd
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
venv/
env/
.python-version

# Build / package artifacts
*.egg-info/
*.egg
build/
dist/
pip-wheel-metadata/

# Editor / IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Local secrets & credentials  ────────────────────────────────────────
# Never commit API keys. Forge reads Sarvam/HF tokens from env vars or
# ~/.config/forge/ — both are outside this tree.
.env
.env.*
secrets.json
sarvam_key.txt
hf_token
*.pem
*.key

# Claude Code local config (may contain user-specific permission rules
# with embedded one-shot tokens — never commit).
.claude/

# Forge runtime artifacts  ─────────────────────────────────────────────
# Render outputs / large generated media — these live in ~/Desktop/forge-test/
# by default and should not be tracked. Anything generated locally inside
# the repo tree is ignored here too.
output/
outputs/
generated/
forge-out/

# LoRA training data + run outputs. The config (train.json) and the
# DATASET.md provenance summary are committed via explicit `git add`.
# Image symlinks, captions, checkpoints, logs, and progress samples
# are not — they regenerate from bin/forge_madhubani_lora.py and the
# rehydrated reference corpus.
training/madhubani_lora/images/
training/madhubani_lora/training/
training/logs/
# mflux-train resolves `checkpoint.output_path` relative to CWD with a
# timestamp suffix, so runs launched from the repo root land here too.
training_*/

# Gallery DB, lock files, and other per-machine runtime state.
.forge-state/
*.mp4
*.mov
*.m4v
*.webm
*.wav
*.mp3
*.m4a
*.aiff

# Models & weights — never commit (lives in ~/Models/)
*.safetensors
*.gguf
*.bin
*.onnx
*.ckpt
*.pt
models/
weights/

# Reference-corpus binaries — keep ONLY the attribution.json manifests in
# git. Anyone can rehydrate the binaries from each attribution.json's
# source_url via `python3 bin/rehydrate_references.py`. This is the standard
# ML pattern: version the manifest, not the (often-licensed, often-large)
# source images. CC BY-SA + redistribution-as-mirror has nuance we'd rather
# not carry forever in git history.
brand/references/**/*.jpg
brand/references/**/*.jpeg
brand/references/**/*.png
brand/references/**/*.webp
brand/references/**/*.gif
brand/references/**/*.tif
brand/references/**/*.tiff
# Allow the example attribution sample (still a JSON, not a binary)
!brand/references/**/_example_attribution.json

# Logs / temp
*.log
*.tmp
*.bak
tmp/
.cache/

# Throwaway one-off render scripts (showcase / verification batches)
# Their intent lives in commit messages; the engines themselves are
# the production surface, not these scripts.
bin/_render_*.sh
